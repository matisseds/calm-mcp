# =============================================================================
# BTP CALM MCP - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# For local development, you also need a default-env.json with VCAP_SERVICES
# =============================================================================

# -----------------------------------------------------------------------------
# SAP Destination Configuration
# -----------------------------------------------------------------------------
# Name of the destination configured in SAP BTP Cockpit
# This destination should point to your target SAP system
CALM_DESTINATION_NAME=YOUR_DESTINATION_NAME

# -----------------------------------------------------------------------------
# Local Development
# -----------------------------------------------------------------------------
# Temporary bypass for app-local XSUAA scope checks during local development.
# Keep this false in shared or production environments.
ALLOW_DEV_SCOPE_BYPASS=false

# Optional override for OAuth redirect base URL.
# Local dashboard flow defaults to http://localhost:3000/dashboard.
# OAUTH_REDIRECT_BASE_URL=http://localhost:3000
